# Database (Supabase PostgreSQL — pooled connection for app queries)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Direct connection for migrations (non-pooled, required by drizzle-kit)
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-region.supabase.com:5432/postgres

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

# Supabase Storage (service role key is server-side only — never expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Security & Verification
# VirusTotal API key for package scanning (free tier: 500 scans/day)
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# Platform Ed25519 signing key (PKCS8 PEM, base64-encoded) — generate with:
# node -e "const c=require('crypto');const{privateKey}=c.generateKeyPairSync('ed25519',{privateKeyEncoding:{type:'pkcs8',format:'pem'}});console.log(privateKey)"
PLATFORM_SIGNING_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Comma-separated Clerk user IDs allowed to trigger manual verification
ADMIN_USER_IDS=user_xxx,user_yyy
