{
  "name": "interns-market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "pnpm --filter @repo/db drizzle-kit generate",
    "db:migrate": "pnpm --filter @repo/db drizzle-kit migrate",
    "db:studio": "pnpm --filter @repo/db drizzle-kit studio"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}
